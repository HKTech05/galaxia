# Database
DATABASE_URL="postgresql://username:password@your-rds-endpoint:5432/galaxia?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"

# AWS S3 — File Storage
AWS_REGION="eu-north-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="galaxia-uploads"

# Encryption — AES-256 key (64 hex chars = 32 bytes)
ENCRYPTION_KEY="generate-a-64-char-hex-string-here-for-production"
